{
  "openapi": "3.0.0",
  "info": {
    "title": "Users API",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "required": ["id", "name", "email"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Customer identification"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "age": {
            "type": "number"
          }
        }
      },
      "Health": {
        "type": "object",
        "required": ["status", "uptimename", "timestamp", "environment"],
        "properties": {
          "status": {
            "type": "string"
          },
          "uptime": {
            "type": "number"
          },
          "timestamp": {
            "type": "string",
            "format": "date"
          },
          "environment": {
            "type": "string"
          }
        }
      }
    }
  }
}
